{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://terra-open-observability.dev/schemas/terra-v1.schema.json",
  "title": "Terra v1 Telemetry Convention",
  "description": "Open telemetry convention for on-device inference and stream telemetry.",
  "version": "v1",
  "required": [
    "schema_version",
    "version",
    "title",
    "required_attributes",
    "allowed_runtime_values",
    "span_names",
    "span_attributes_ms",
    "streaming",
    "hardware"
  ],
  "type": "object",
  "properties": {
    "schema_version": {
      "const": "v1"
    },
    "version": {
      "const": "v1"
    },
    "title": {
      "type": "string"
    },
    "required_attributes": {
      "type": "object",
      "required": [
        "terra.semantic.version",
        "terra.schema.family",
        "terra.runtime",
        "terra.request.id",
        "terra.session.id",
        "terra.model.fingerprint"
      ],
      "properties": {
        "terra.semantic.version": {
          "const": "v1"
        },
        "terra.schema.family": {
          "const": "terra"
        },
        "terra.runtime": {
          "type": "string",
          "enum": [
            "coreml",
            "foundation_models",
            "mlx",
            "ollama",
            "lm_studio",
            "llama_cpp",
            "openclaw_gateway",
            "http_api"
          ]
        },
        "terra.request.id": {
          "type": "string"
        },
        "terra.session.id": {
          "type": "string"
        },
        "terra.model.fingerprint": {
          "type": "string"
        }
      },
      "additionalProperties": {
        "type": ["string", "number", "boolean", "null"]
      }
    },
    "allowed_runtime_values": {
      "type": "array",
      "minItems": 8,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "coreml",
          "foundation_models",
          "mlx",
          "ollama",
          "lm_studio",
          "llama_cpp",
          "openclaw_gateway",
          "http_api"
        ]
      }
    },
    "span_names": {
      "type": "object",
      "required": [
        "root",
        "inference",
        "stage_prompt_eval",
        "stage_decode",
        "stream_lifecycle"
      ],
      "properties": {
        "root": {
          "const": "terra.model.load"
        },
        "inference": {
          "const": "terra.inference"
        },
        "stage_prompt_eval": {
          "const": "terra.stage.prompt_eval"
        },
        "stage_decode": {
          "const": "terra.stage.decode"
        },
        "stream_lifecycle": {
          "const": "terra.stream.lifecycle"
        }
      },
      "additionalProperties": false
    },
    "span_attributes_ms": {
      "type": "object",
      "required": [
        "terra.latency.ttft_ms",
        "terra.latency.e2e_ms",
        "terra.latency.prompt_eval_ms",
        "terra.latency.decode_ms",
        "terra.latency.tail_p95_ms",
        "terra.latency.tail_p99_ms"
      ],
      "properties": {
        "terra.latency.ttft_ms": {
          "type": "number",
          "minimum": 0
        },
        "terra.latency.e2e_ms": {
          "type": "number",
          "minimum": 0
        },
        "terra.latency.prompt_eval_ms": {
          "type": "number",
          "minimum": 0
        },
        "terra.latency.decode_ms": {
          "type": "number",
          "minimum": 0
        },
        "terra.latency.tail_p95_ms": {
          "type": "number",
          "minimum": 0
        },
        "terra.latency.tail_p99_ms": {
          "type": "number",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "streaming": {
      "type": "object",
      "required": [
        "events",
        "attributes"
      ],
      "properties": {
        "events": {
          "type": "object",
          "required": [
            "terra.token.lifecycle",
            "terra.first_token",
            "terra.stage.prompt_eval",
            "terra.stage.decode"
          ],
          "properties": {
            "terra.token.lifecycle": {
              "type": "string"
            },
            "terra.first_token": {
              "type": "string"
            },
            "terra.stage.prompt_eval": {
              "type": "string"
            },
            "terra.stage.decode": {
              "type": "string"
            },
            "terra.anomaly.stalled_token": {
              "type": "string"
            },
            "terra.anomaly.model_regression": {
              "type": "string"
            },
            "terra.anomaly.hardware_correlation": {
              "type": "string"
            }
          },
          "additionalProperties": true
        },
        "attributes": {
          "type": "object",
          "required": [
            "terra.token.index",
            "terra.token.gap_ms",
            "terra.token.stage"
          ],
          "properties": {
            "terra.token.index": {
              "type": "integer",
              "minimum": 0
            },
            "terra.token.gap_ms": {
              "type": "number",
              "minimum": 0
            },
            "terra.token.stage": {
              "type": "string",
              "enum": [
                "model_load",
                "prompt_eval",
                "decode",
                "finish"
              ]
            },
            "terra.token.logprob": {
              "type": "number"
            },
            "terra.stall.threshold_ms": {
              "type": "number",
              "minimum": 0
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "hardware": {
      "type": "object",
      "required": [
        "terra.process.thermal_state",
        "terra.hw.power_state",
        "terra.hw.memory_pressure"
      ],
      "properties": {
        "terra.process.thermal_state": {
          "type": "string"
        },
        "terra.hw.power_state": {
          "type": "string"
        },
        "terra.hw.memory_pressure": {
          "type": "string"
        },
        "terra.process.memory_resident_delta_mb": {
          "type": "number",
          "minimum": 0
        },
        "terra.process.memory_peak_mb": {
          "type": "number",
          "minimum": 0
        },
        "terra.hw.rss_mb": {
          "type": "number",
          "minimum": 0
        },
        "terra.hw.memory_churn_mb": {
          "type": "number"
        },
        "terra.hw.gpu_occupancy_pct": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "terra.hw.ane_utilization_pct": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        }
      },
      "additionalProperties": false
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "severity", "created_at"],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "slowdown_thermal_throttling",
              "prompt_cache_miss_likely",
              "model_swap_regression",
              "stalled_token_excess",
              "runtime_error_rate_increase"
            ]
          },
          "severity": {
            "type": "string",
            "enum": ["info", "warning", "critical"]
          },
          "created_at": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "action_hint": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
